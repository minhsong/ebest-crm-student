# Copy file này thành .env.local và sửa giá trị.

# Base URL của CRM API (server-side only, không lộ ra client).
# Dùng cho: SSR load profile-by-token, API route /api/profile forward PATCH.
# Ví dụ:
#   - Local:  http://localhost:3001
#   - Production: https://api.ebest.edu.vn
CRM_API_URL=http://localhost:3001
