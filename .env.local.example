# ===========================================
# Student Portal - Environment config
# ===========================================
# Copy file này thành .env.local và sửa giá trị.

# Base URL của CRM API (server-side only, không lộ ra client).
# Dùng cho: SSR profile-by-token, API proxy tỉnh/phường (/api/vietnam-administrative), /api/profile, ...
# Phải trỏ tới server NestJS (CRM API), không trỏ tới URL Student Portal.
# Ví dụ: Student Portal 3000, CRM API 3001 → http://localhost:3001
CRM_API_URL=http://localhost:3001

# --- Quiz runtime (server Portal → CRM verify session → Social Gateway) ---
# Xác thực học viên chỉ qua CRM (`GET /api/v1/student/me` + Passport) — không verify JWT trên Portal.
# Gateway + token máy–máy (trùng cặp với CRM publish / gateway CRM_SERVICE_TOKEN).
SOCIAL_GATEWAY_BASE_URL=http://localhost:3040
SOCIAL_GATEWAY_SERVICE_TOKEN=

# Socket.IO (browser): origin gateway + path khớp gateway `WS_PATH` (mặc định /socket.io).
NEXT_PUBLIC_SOCIAL_GATEWAY_WS_ORIGIN=http://localhost:3040
# NEXT_PUBLIC_SOCIAL_GATEWAY_WS_PATH=/socket.io

# Trên server CRM (NestJS), cần có thêm cho quên mật khẩu học viên:
# AUTH_STUDENT_FORGOT_SECRET, AUTH_STUDENT_FORGOT_TOKEN_EXPIRES_IN=1d,
# STUDENT_PORTAL_ORIGIN trùng URL công khai của cổng học viên (vd. https://student...).

# URL gốc của Student Portal (dùng cho Open Graph / social sharing).
# Nếu không set, ảnh thumbnail share sẽ dùng đường dẫn tương đối.
# Ví dụ: https://student.ebest.edu.vn
# SITE_URL=https://student.ebest.edu.vn
