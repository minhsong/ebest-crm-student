{
  "name": "ebest-student-portal",
  "version": "0.1.0",
  "private": true,
  "description": "Student portal - complete profile & student dashboard (e.g. student.ebest.edu.vn)",
  "scripts": {
    "predev": "node scripts/ensure-crm-api-types-built.js && node scripts/ensure-game-packages-built.js",
    "dev": "next dev -p 3001",
    "prebuild": "node scripts/ensure-crm-api-types-built.js && node scripts/ensure-game-packages-built.js",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:public": "playwright test --project=games-hub-public",
    "test:e2e:games-hub": "playwright test e2e/games-hub"
  },
  "dependencies": {
    "@ant-design/nextjs-registry": "^1.0.2",
    "@ebest/crm-api-types": "file:../ebest-crm-api/packages/crm-api-types",
    "@ebest/game-engine-core": "file:../ebest-game/game-engine-core",
    "@ebest/game-vocabulary-drill": "file:../ebest-game/game-vocabulary-drill",
    "@react-oauth/google": "^0.13.4",
    "@tiptap/extension-link": "^3.28.0",
    "@tiptap/extension-placeholder": "^3.28.0",
    "@tiptap/extension-underline": "^3.28.0",
    "@tiptap/pm": "^3.28.0",
    "@tiptap/react": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "antd": "^5.22.0",
    "dayjs": "^1.11.13",
    "libphonenumber-js": "^1.12.38",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-phone-number-input": "^3.4.16",
    "react-player": "^3.4.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
